{
  "name": "sheryassets",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "lint-staged": {
  "apps/web/**/*.{ts,tsx,js,jsx}": [
    "bun --cwd apps/web lint:fix",
    "bun --cwd apps/web build"
  ],
  "apps/server/**/*.{ts,js}": [
    "bun --cwd apps/server lint:fix",
    "bun --cwd apps/server build"
  ]
},
  "scripts": {
    "dev": "concurrently \"bun run dev:web\" \"bun run dev:server\"",
    "build": "concurrently \"bun run build:web\" \"bun run build:server\"",
    "dev:web": "bun --cwd apps/web dev",
    "dev:server": "bun --cwd apps/server dev",
    "build:web": "bun --cwd apps/web build",
    "build:server": "bun --cwd apps/server build",
    "lint": "bun --cwd apps/web lint && bun --cwd apps/server lint",
    "format": "bunx prettier --write .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "concurrently": "^9.2.1",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript-eslint": "^8.58.0"
  }
}
