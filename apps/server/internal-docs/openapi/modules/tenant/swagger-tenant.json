          {
            "type": "object",
            "properties": {
              "role": {
                "type": "string",
                "enum": [
                  "owner",
                  "admin",
                  "member"
                ],
                "example": "owner"
              }
            },
            "required": [
              "role"
            ]
          }
        ]
      },
      "TenantSuccessEnvelope": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
