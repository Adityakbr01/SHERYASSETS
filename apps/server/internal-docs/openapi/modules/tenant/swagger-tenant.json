{
  "openapi": "3.0.0",
  "info": {
    "title": "SHERYASSETS API",
    "version": "1.0.0",
    "description": "API Documentation for SheryAssets"
  },
  "servers": [
    {
      "url": "http://localhost:5000",
      "description": "Local development server"
    }
  ],
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT"
      },
      "cookieAuth": {
        "type": "apiKey",
        "in": "cookie",
        "name": "accessToken"
      },
      "apiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key"
      }
    },
    "schemas": {
      "AuthErrorItem": {
        "type": "object",
        "properties": {
          "code": {
            "type": "string",
            "example": "INVALID_TYPE"
          },
          "path": {
            "type": "array",
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "number"
                }
              ]
            },
            "example": [
              "body",
              "email"
            ]
          },
          "message": {
            "type": "string",
            "example": "Valid email is required"
          }
        },
        "required": [
          "code",
          "path",
          "message"
        ]
      },
      "AuthErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ],
            "example": false
          },
          "message": {
            "type": "string",
            "example": "Validation failed"
          },
          "errorCode": {
            "type": "string",
            "example": "UNAUTHORIZED"
          },
          "errors": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/AuthErrorItem"
            }
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "AuthUser": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f2d6"
          },
          "name": {
            "type": "string",
            "example": "Aaditya Sharma"
          },
          "email": {
            "type": "string",
            "format": "email",
            "example": "aaditya@sheryassets.com"
          },
          "role": {
            "type": "string",
            "example": "user"
          },
          "isEmailVerified": {
            "type": "boolean",
            "example": true
          }
        },
        "required": [
          "_id",
          "name",
          "email",
          "role",
          "isEmailVerified"
        ]
      },
      "AuthTenant": {
        "type": "object",
        "properties": {
          "tenantId": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f2e1"
          },
          "role": {
            "type": "string",
            "enum": [
              "owner",
              "admin",
              "member"
            ],
            "example": "owner"
          },
          "name": {
            "type": "string",
            "example": "SheryAssets Workspace"
          },
          "slug": {
            "type": "string",
            "example": "sheryassets-workspace"
          }
        },
        "required": [
          "tenantId",
          "role",
          "name",
          "slug"
        ]
      },
      "AuthTokens": {
        "type": "object",
        "properties": {
          "accessToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.access-token"
          },
          "refreshToken": {
            "type": "string",
            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.refresh-token"
          }
        },
        "required": [
          "accessToken",
          "refreshToken"
        ]
      },
      "AuthSuccessEnvelope": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ],
            "example": true
          },
          "message": {
            "type": "string",
            "example": "Operation successful"
          },
          "data": {
            "nullable": true
          },
          "meta": {
            "nullable": true
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "AuthLoginRegisterResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
            "type": "string",
            "example": "Login successful"
          },
          "data": {
            "type": "object",
            "properties": {
              "user": {
                "$ref": "#/components/schemas/AuthUser"
              },
              "tenants": {
                "type": "array",
                "items": {
                  "$ref": "#/components/schemas/AuthTenant"
                }
              },
              "accessToken": {
                "type": "string",
                "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.access-token"
              },
              "refreshToken": {
                "type": "string",
                "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.refresh-token"
              }
            },
            "required": [
              "user",
              "tenants",
              "accessToken",
              "refreshToken"
            ]
          }
        },
        "required": [
          "success",
          "message",
          "data"
        ]
      },
      "AuthSwitchTenantResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
            "type": "string",
            "example": "Tenant switched successfully"
          },
          "data": {
            "type": "object",
            "properties": {
              "accessToken": {
                "type": "string",
                "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.new-access-token"
              },
              "tenant": {
                "$ref": "#/components/schemas/AuthTenant"
              }
            },
            "required": [
              "accessToken",
              "tenant"
            ]
          }
        },
        "required": [
          "success",
          "message",
          "data"
        ]
      },
      "AuthCurrentUserResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
            "type": "string",
            "example": "Current user fetched"
          },
          "data": {
            "allOf": [
              {
                "$ref": "#/components/schemas/AuthUser"
              },
              {
                "type": "object",
                "properties": {
                  "tenants": {
                    "type": "array",
                    "items": {
                      "$ref": "#/components/schemas/AuthTenant"
                    }
                  }
                },
                "required": [
                  "tenants"
                ]
              }
            ]
          }
        },
        "required": [
          "success",
          "message",
          "data"
        ]
      },
      "BillingErrorResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              false
            ]
          },
          "message": {
            "type": "string",
            "example": "Payment verification failed"
          },
          "errorCode": {
            "type": "string"
          },
          "errors": {
            "type": "array",
            "items": {
              "nullable": true
            }
          }
        },
        "required": [
          "success",
          "message"
        ]
      },
      "BillingSubscriptionIntent": {
        "type": "object",
        "properties": {
          "orderId": {
            "type": "string",
            "example": "order_Q31k8jx9WJ9V0a"
          },
          "amount": {
            "type": "number",
            "example": 2900,
            "description": "Amount in paise"
          },
          "currency": {
            "type": "string",
            "example": "INR"
          },
          "subscriptionId": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f5b9"
          }
        },
        "required": [
          "orderId",
          "amount",
          "currency",
          "subscriptionId"
        ]
      },
      "BillingSubscriptionRecord": {
        "type": "object",
        "properties": {
          "_id": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f5b9"
          },
          "tenantId": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f2e1"
          },
          "planId": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f2ef"
          },
          "userId": {
            "type": "string",
            "example": "67f0be5b5998de9765a2f2d6"
          },
          "razorpayOrderId": {
            "type": "string",
            "example": "order_Q31k8jx9WJ9V0a"
          },
          "razorpayPaymentId": {
            "type": "string",
            "nullable": true,
            "example": "pay_Q31lL9Vd2kacZs"
          },
          "amount": {
            "type": "number",
            "example": 29
          },
          "status": {
            "type": "string",
            "enum": [
              "created",
              "active",
              "failed",
              "cancelled"
            ],
            "example": "active"
          },
          "startDate": {
            "type": "string",
            "format": "date-time",
            "example": "2026-04-05T12:08:12.000Z"
          },
          "endDate": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-05T12:08:12.000Z"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "_id",
          "tenantId",
          "planId",
          "userId",
          "razorpayOrderId",
          "amount",
          "status"
        ]
      },
      "BillingSuccessEnvelope": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean",
            "enum": [
              true
            ]
          },
          "message": {
