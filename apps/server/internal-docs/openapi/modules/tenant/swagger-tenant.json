          "billingEmail": {
            "type": "string",
            "format": "email",
            "example": "founder@sheryassets.com"
          },
          "subscriptionStatus": {
            "type": "string",
            "nullable": true,
            "example": "active"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          },
          "updatedAt": {
            "type": "string",
            "format": "date-time"
          }
        },
        "required": [
          "_id",
          "name",
          "slug",
          "ownerUserId",
          "planId",
          "status",
          "billingEmail"
        ]
      },
      "TenantWithRole": {
        "allOf": [
