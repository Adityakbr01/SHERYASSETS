{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "SheryAssets",
  "public": false,
  "colors": {
    "primary": "#F59E0B",
    "light": "#F59E0B",
    "dark": "#D97706"
  },
  "favicon": "/favicon.png",
  "api": {
    "playground": {
      "display": "interactive"
    },
    "params": {
      "expanded": "all"
    }
  },
  "navigation": {
    "groups": [
      {
        "group": "Getting Started",
        "pages": [
          "openapi/modules/introduction",
          "openapi/modules/getting-started",
          "openapi/modules/quickstart"
        ]
      },
      {
        "group": "Modules",
        "pages": [
          "openapi/modules/overview",
          "openapi/modules/auth/authentication",
          "openapi/modules/tenant/tenant",
          "openapi/modules/membership/membership",
          "openapi/modules/apikey/apikeys",
          "openapi/modules/plan/plans",
          "openapi/modules/billing/billing",
          "openapi/modules/assets/upload",
          "openapi/modules/usage/usage"
        ]
      },
      {
        "group": "Developer Help",
        "pages": [
          "openapi/modules/developer-onboarding-checklist",
          "openapi/modules/api-recipes",
          "openapi/modules/pricing-and-roadmap",
          "openapi/modules/troubleshooting",
          "openapi/modules/search-index"
        ]
      },
      {
        "group": "API Reference",
        "root": "openapi/modules/api-reference",
        "pages": [
          {
            "group": "API Auth",
            "openapi": {
              "source": "openapi/modules/auth/swagger-auth.json",
              "directory": "api/auth"
            }
          },
          {
            "group": "API Billing",
            "openapi": {
              "source": "openapi/modules/billing/swagger-billing.json",
              "directory": "api/billing"
            }
          },
          {
            "group": "API Tenant",
            "openapi": {
              "source": "openapi/modules/tenant/swagger-tenant.json",
              "directory": "api/tenant"
            }
          },
          {
            "group": "API Membership",
            "openapi": {
              "source": "openapi/modules/membership/swagger-membership.json",
              "directory": "api/membership"
            }
          },
          {
            "group": "API ApiKey",
            "openapi": {
              "source": "openapi/modules/apikey/swagger-apikey.json",
              "directory": "api/apikey"
            }
          },
          {
            "group": "API Asset",
            "openapi": {
              "source": "openapi/modules/assets/swagger-asset.json",
              "directory": "api/asset"
            }
          },
          {
            "group": "API Usage",
            "openapi": {
              "source": "openapi/modules/usage/swagger-usage.json",
              "directory": "api/usage"
            }
          },
          {
            "group": "API Plan",
            "openapi": {
              "source": "openapi/modules/plan/swagger-plan.json",
              "directory": "api/plan"
            }
          }
        ]
      }
    ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Support",
        "href": "mailto:support@sheryassets.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Started",
      "href": "https://sheryassets.com/dashboard"
    }
  },
  "contextual": {
    "display": "header",
    "options": [
      "copy",
      "chatgpt",
      "claude"
    ]
  }
}