{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "build": "bun run lint && bun run clean && bunx tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json",
    "prestart": "bun run build",
    "start": "bun dist/server.js",
    "start:pm2": "pm2 start dist/server.js --name sheryassets-server --interpreter bun",
    "format": "bunx prettier --write .",
    "format:check": "bunx prettier --check .",
    "lint": "bunx eslint .",
    "lint:fix": "bunx eslint . --fix",
    "test": "bun test src/__tests__/*.test.ts --timeout 30000",
    "test:auth": "bun test src/__tests__/auth.test.ts --timeout 30000",
    "test:tenant": "bun test src/__tests__/tenant.test.ts --timeout 30000",
    "test:membership": "bun test src/__tests__/membership.test.ts --timeout 30000",
    "test:apikey": "bun test src/__tests__/apikey.test.ts --timeout 30000",
    "test:plan": "bun test src/__tests__/plan.test.ts --timeout 30000",
    "test:billing": "bun test src/__tests__/billing.test.ts --timeout 30000",
    "test:middleware": "bun test src/__tests__/middleware.test.ts --timeout 30000",
    "test:asset": "bun test src/__tests__/asset.test.ts --timeout 30000",
    "test:usage": "bun test src/__tests__/usage.test.ts --timeout 30000",
    "ngrok:start": "docker compose -f docker-compose.ngrok.yml up -d",
    "ngrok:stop": "docker compose -f docker-compose.ngrok.yml down",
    "ngrok:restart": "docker compose -f docker-compose.ngrok.yml down && docker compose -f docker-compose.ngrok.yml up -d",
    "ngrok:logs": "docker compose -f docker-compose.ngrok.yml logs -f ngrok"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/busboy": "^1.5.4",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.5.0",
    "@types/supertest": "^7.2.0",
    "@types/uuid": "^11.0.0",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.16",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.71.1",
    "busboy": "^1.6.0",
    "compression": "^1.8.1",
    "cookie-parse": "^0.4.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "install": "^0.13.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.3.3",
    "morgan": "^1.10.1",
    "multer": "^2.1.1",
    "razorpay": "^2.9.6",
    "resend": "^6.10.0",
    "sharp": "^0.34.5",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "tsconfig-paths": "^4.2.0",
    "uuid": "^13.0.0",
    "winston": "^3.19.0",
    "zod": "^4.3.6"
  }
}